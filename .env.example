# Supabase project URL (e.g., https://your-project-ref.supabase.co)
SUPABASE_URL=

# Supabase Service Role Key (found in Project Settings -> API) - KEEP THIS SECRET!
SUPABASE_SERVICE_ROLE=

# The UUID of this printer as registered in your Supabase 'printers' table
PRINTER_ID=80c70eec-1a27-4c0b-8683-698a9a014e94

# (Optional) The exact name of the printer as it appears in Windows Control Panel -> Devices and Printers.
# If left empty, the agent will attempt to use the system's default printer.
PRINTER_NAME='Epson L130'

# (Optional) The full path to the LibreOffice 'soffice.exe' executable,
# needed for converting DOCX/PPT/PPTX to PDF.
# Example: C:\Program Files\LibreOffice\program\soffice.exe
# If not set, the agent will try to find it in common locations or assume it's in your system PATH.
LIBREOFFICE_PATH=

# (Optional) Polling interval in seconds (default is 3 seconds).
# POLL_INTERVAL=3